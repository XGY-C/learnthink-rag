# Retriever mode: "milvus" (default) or "jsonl" (fallback)
RETRIEVER_MODE=milvus

# Milvus connection — 两种方式（二选一）
# 方式 A: Milvus Lite 嵌入式（开发首选，零外部依赖，Windows/Mac/Linux 通用）
MILVUS_URI=./milvus_data/learnthink.db
# 方式 B: Milvus Standalone（Docker / 远程服务器，取消注释并注释 MILVUS_URI）
# MILVUS_HOST=localhost
# MILVUS_PORT=19530
# MILVUS_DB=learnthink

# Embedding
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
EMBEDDING_CACHE_DIR=./models

# Knowledge base base path
KB_BASE_DIR=../kb
INDEX_FILENAME=chunks.jsonl

# Excerpt max chars in returned sources
EXCERPT_MAX_CHARS=320

# Alibaba Cloud OSS Configuration (required for document ingestion)
OSS_ACCESS_KEY=your-access-key-id
OSS_SECRET_KEY=your-access-key-secret
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET_NAME=learnthink-rag
