# Retriever mode: "milvus" (default) or "jsonl" (fallback)
RETRIEVER_MODE=milvus

# Milvus Standalone（Docker / 远程服务器）
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_DB=learnthink

# Embedding
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
EMBEDDING_CACHE_DIR=./models

# Hybrid search
SEARCH_MODE=hybrid
SPARSE_WEIGHT=0.3

# Knowledge base
KB_BASE_DIR=./kb
EXCERPT_MAX_CHARS=320
